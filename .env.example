# ==============================================================================
# BSP ID Web — Environment Variables
# Copy this file to .env.local and fill in the values before running locally.
# Never commit .env.local to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Aptos network
# Options: testnet | mainnet | devnet
# Use testnet for local development; switch to mainnet before going live.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APTOS_NETWORK=testnet

# ------------------------------------------------------------------------------
# BSP Contract Address on Aptos
# The address of the deployed BSP Move module on the Aptos network.
# Obtain this after deploying the contracts from the bsp-contracts repository.
# Leave blank to run in read-only / demo mode (no writes to chain).
# ------------------------------------------------------------------------------
NEXT_PUBLIC_BSP_CONTRACT_ADDRESS=

# ------------------------------------------------------------------------------
# BSP Registry API base URL
# The registry API that indexes BEO/IEO records for fast lookup.
# ------------------------------------------------------------------------------
BSP_REGISTRY_URL=https://registry.biologicalsovereigntyprotocol.com

# ------------------------------------------------------------------------------
# Operator alerts (optional)
# Fires an alert when the operator wallet APT balance drops below the threshold.
# ------------------------------------------------------------------------------

# Minimum APT balance before alert (float, e.g. 1.0 = 1 APT)
APTOS_BALANCE_ALERT_THRESHOLD=1.0

# Email address that receives low-balance alerts
ALERT_EMAIL=ops@yourorg.com

# ------------------------------------------------------------------------------
# Public app config (exposed to the browser — safe, no secrets)
# ------------------------------------------------------------------------------

# Canonical public URL for this deployment (used in OG tags, canonical links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default UI locale (e.g. pt-BR, en, es)
NEXT_PUBLIC_DEFAULT_LOCALE=pt-BR

# Aptos block explorer base URL — transaction hashes are appended to this
NEXT_PUBLIC_EXPLORER_URL=https://explorer.aptoslabs.com/txn/

# ------------------------------------------------------------------------------
# Demo mode
# When true, all flows work locally without calling API/Aptos.
# Keys are generated for real (Ed25519), but on-chain registration is simulated.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_DEMO_MODE=false
