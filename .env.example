# ==============================================================================
# BSP ID Web — Environment Variables
# Copy this file to .env.local and fill in the values before running locally.
# Never commit .env.local to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Arweave network
# Options: testnet | mainnet
# Use testnet for local development; switch to mainnet before going live.
# ------------------------------------------------------------------------------
ARWEAVE_NETWORK=testnet

# ------------------------------------------------------------------------------
# Arweave operator wallet (JSON Web Key — JWK format)
# This wallet pays Arweave gas on behalf of users (gasless relay).
# Keep this secret — it is server-side only (no NEXT_PUBLIC_ prefix).
# Generate a new wallet: https://faucet.arweave.net/ (testnet) or Arconnect.
# ------------------------------------------------------------------------------
ARWEAVE_OPERATOR_KEY={"kty":"RSA","n":"..."}

# ------------------------------------------------------------------------------
# BSP Registry API base URL
# The registry API that indexes BEO/IEO records for fast lookup.
# ------------------------------------------------------------------------------
BSP_REGISTRY_URL=https://registry.biologicalsovereigntyprotocol.com

# ------------------------------------------------------------------------------
# AO Process IDs
# Obtain these after deploying the processes from the bsp-contracts repository.
# Leave blank to run in read-only / demo mode (no writes to chain).
# ------------------------------------------------------------------------------

# BEO Registry — stores Biological Entity Object records
BSP_PROCESS_BEO_REGISTRY=

# IEO Registry — stores Institutional Entity Object records
BSP_PROCESS_IEO_REGISTRY=

# Domain Registry — manages .bsp domain name assignments
BSP_PROCESS_DOMAIN_REGISTRY=

# Access Control — enforces ConsentToken read/write permissions
BSP_PROCESS_ACCESS_CONTROL=

# ------------------------------------------------------------------------------
# Operator alerts (optional)
# Fires an alert when the operator wallet AR balance drops below the threshold.
# ------------------------------------------------------------------------------

# Minimum AR balance before alert (float, e.g. 1.0 = 1 AR)
ARWEAVE_BALANCE_ALERT_THRESHOLD=1.0

# Email address that receives low-balance alerts
ALERT_EMAIL=ops@yourorg.com

# ------------------------------------------------------------------------------
# Public app config (exposed to the browser — safe, no secrets)
# ------------------------------------------------------------------------------

# Canonical public URL for this deployment (used in OG tags, canonical links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default UI locale (e.g. pt-BR, en, es)
NEXT_PUBLIC_DEFAULT_LOCALE=pt-BR

# Arweave block explorer base URL — transaction hashes are appended to this
NEXT_PUBLIC_EXPLORER_URL=https://viewblock.io/arweave/tx/

# ------------------------------------------------------------------------------
# Demo mode
# When true, all flows work locally without calling API/Arweave.
# Keys are generated for real (Ed25519), but on-chain registration is simulated.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_DEMO_MODE=false
